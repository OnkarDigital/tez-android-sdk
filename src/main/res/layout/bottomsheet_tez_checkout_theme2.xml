<?xml version="1.0" encoding="utf-8"?>
<!--
    TezGateway SDK — Theme 2 (Cyberpunk Dark Layout)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tez_bottom_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0E0E18">

    <!-- DRAG HANDLE -->
    <View
        android:id="@+id/tez_drag_handle"
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="0dp"
        android:background="#3E3E50" />

    <!-- HEADER BAR (Sleek Dark Header) -->
    <LinearLayout
        android:id="@+id/tez_header_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="16dp"
        android:background="#08080F">

        <!-- Shield Icon -->
        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/tez_drag_handle_bg"
            android:backgroundTint="#1AFFFFFF"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🛡️"
                android:textSize="18sp" />
        </FrameLayout>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tez_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure Express Checkout"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tez_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Native 256-bit encrypted gateway"
                android:textColor="#8E8EA8"
                android:textSize="9.5sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Branding Badge -->
        <LinearLayout
            android:id="@+id/tez_branding_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by"
                android:textColor="#8E8EA8"
                android:textSize="8sp" />

            <ImageView
                android:id="@+id/tez_branding_logo"
                android:layout_width="80dp"
                android:layout_height="18dp"
                android:scaleType="fitEnd"
                android:alpha="0.8" />
        </LinearLayout>
    </LinearLayout>

    <!-- Header glow boundary line instead of drop shadow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF" />

    <!-- SCROLLABLE BODY -->
    <ScrollView
        android:id="@+id/tez_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- PAYMENT SELECTION SECTION -->
            <LinearLayout
                android:id="@+id/tez_payment_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- AMOUNT CARD (Premium Translucent Gradient) -->
                <LinearLayout
                    android:id="@+id/tez_amount_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tez_amount_label_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AMOUNT TO PAY"
                        android:textColor="#A78BFA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tez_amount_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="₹500.00" />
                </LinearLayout>

                <!-- SECTION LABEL: UPI Apps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="#A78BFA" />

                    <TextView
                        android:id="@+id/tez_pay_upi_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT UPI METHOD"
                        android:textSize="10sp"
                        android:textColor="#8E8EA8"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- UPI HORIZONTAL SCROLL LIST (Completely different layout) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_gpay"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="Google Pay"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_gpay"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_phonepe"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="PhonePe"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_phonepe"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_paytm"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="Paytm"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_paytm"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_bhim"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="BHIM UPI"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_bhim"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_amazonpay"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="Amazon"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_amazonpay"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cred"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="116dp"
                            android:layout_height="72dp"
                            android:layout_margin="4dp"
                            android:text="CRED"
                            android:textSize="10.5sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_cred"
                            app:iconGravity="top"
                            app:iconTint="@null"
                            app:iconSize="26dp"
                            app:iconPadding="4dp"
                            app:backgroundTint="#1AFFFFFF" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- TRUST ROW -->
                <LinearLayout
                    android:id="@+id/tez_trust_row"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  Secure"
                        android:textSize="10sp"
                        android:textColor="#4ADE80"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#1B5E20" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Fast"
                        android:textSize="10sp"
                        android:textColor="#4ADE80"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#1B5E20" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Native UPI"
                        android:textSize="10sp"
                        android:textColor="#4ADE80"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- OR SCAN QR DIVIDER -->
                <LinearLayout
                    android:id="@+id/tez_or_divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1AFFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR SCAN SECURE QR  "
                        android:textSize="10sp"
                        android:textColor="#8E8EA8"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1AFFFFFF" />
                </LinearLayout>

                <!-- QR CARD (Glassmorphic dark card) -->
                <LinearLayout
                    android:id="@+id/tez_qr_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <!-- White QR code background (QR image requires high contrast to scan) -->
                    <FrameLayout
                        android:layout_width="168dp"
                        android:layout_height="168dp"
                        android:background="#FFFFFF"
                        android:padding="6dp">

                        <ImageView
                            android:id="@+id/tez_qr_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tez_qr_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Scan using any UPI application"
                        android:textSize="11sp"
                        android:textColor="#8E8EA8"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_qr_paid"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="I've Paid — Check Status"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:cornerRadius="14dp"
                        app:elevation="0dp" />
                </LinearLayout>

            </LinearLayout>
            <!-- end payment section -->

            <!-- STATUS CHECKING SECTION -->
            <LinearLayout
                android:id="@+id/tez_checking_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="16dp"
                android:layout_marginBottom="6dp">

                <!-- Spinner wrap -->
                <FrameLayout
                    android:id="@+id/tez_spinner_wrap"
                    android:layout_width="88dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="14dp">

                    <ProgressBar
                        android:id="@+id/tez_status_spinner"
                        style="@android:style/Widget.ProgressBar.Large"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <ImageView
                        android:id="@+id/tez_spinner_logo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tez_status_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Verifying transaction..."
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tez_status_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Checking... 0s"
                    android:textSize="13sp"
                    android:textColor="#8E8EA8"
                    android:layout_marginBottom="14dp" />

                <!-- Result Card -->
                <LinearLayout
                    android:id="@+id/tez_result_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tez_result_icon_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="52sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tez_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tez_result_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:textColor="#8E8EA8" />
                </LinearLayout>

                <!-- Check status button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_check_status"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Check Status Now"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@android:color/transparent"
                    android:layout_marginBottom="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
            <!-- end checking section -->

            <!-- CANCEL BUTTON -->
            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:text="Cancel Payment"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- NEWS TICKER -->
    <LinearLayout
        android:id="@+id/tez_news_ticker_container"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Left speaker band -->
        <LinearLayout
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="#E65100">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📢"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tez_news_ticker"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:background="#221C0F"
            android:textColor="#FFE082"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

</LinearLayout>
