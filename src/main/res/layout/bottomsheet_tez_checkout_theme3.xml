<?xml version="1.0" encoding="utf-8"?>
<!--
    TezGateway SDK — Theme 3 (Neo-Brutalism Layout)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tez_bottom_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FAF9F6">

    <!-- DRAG HANDLE -->
    <View
        android:id="@+id/tez_drag_handle"
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="0dp"
        android:background="#000000" />

    <!-- HEADER BAR (High Contrast White with thick bottom border) -->
    <LinearLayout
        android:id="@+id/tez_header_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <!-- Square lock badge -->
        <LinearLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:layout_marginEnd="12dp"
            android:borderWidth="2dp"
            android:borderColor="#000000">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tez_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete Payment"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tez_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100% Secure Transaction"
                android:textColor="#555555"
                android:textSize="9.5sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Branding badge -->
        <LinearLayout
            android:id="@+id/tez_branding_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gateway"
                android:textColor="#000000"
                android:textSize="8sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/tez_branding_logo"
                android:layout_width="80dp"
                android:layout_height="18dp"
                android:scaleType="fitEnd" />
        </LinearLayout>
    </LinearLayout>

    <!-- Thick bottom border separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#000000" />

    <!-- SCROLLABLE BODY -->
    <ScrollView
        android:id="@+id/tez_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- PAYMENT SELECTION SECTION -->
            <LinearLayout
                android:id="@+id/tez_payment_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- AMOUNT CARD (White box, 2.5dp black border) -->
                <LinearLayout
                    android:id="@+id/tez_amount_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tez_amount_label_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AMOUNT TO PAY"
                        android:textColor="#000000"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tez_amount_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="₹500.00" />
                </LinearLayout>

                <!-- SECTION LABEL: UPI Apps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="#000000" />

                    <TextView
                        android:id="@+id/tez_pay_upi_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAY VIA UPI APP"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- UPI 2-COLUMN GRID (Completely different layout) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:useDefaultMargins="false"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_gpay"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Google Pay"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_gpay"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_phonepe"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="PhonePe"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_phonepe"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paytm"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Paytm"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_paytm"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bhim"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="BHIM UPI"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_bhim"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_amazonpay"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Amazon Pay"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_amazonpay"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cred"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="CRED"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_cred"
                        app:iconGravity="start"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconPadding="6dp" />
                </GridLayout>

                <!-- TRUST ROW -->
                <LinearLayout
                    android:id="@+id/tez_trust_row"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  Secure"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Fast"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Native UPI"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- OR SCAN QR DIVIDER -->
                <LinearLayout
                    android:id="@+id/tez_or_divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1.5dp"
                        android:layout_weight="1"
                        android:background="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR SCAN QR  "
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1.5dp"
                        android:layout_weight="1"
                        android:background="#000000" />
                </LinearLayout>

                <!-- QR CARD (Neo Brutalist Box) -->
                <LinearLayout
                    android:id="@+id/tez_qr_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/tez_qr_image"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitCenter"
                        android:background="#FFFFFF"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/tez_qr_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open any UPI app and scan this QR code"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btn_qr_paid"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="I've Paid — Check Status"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:elevation="0dp" />
                </LinearLayout>

            </LinearLayout>
            <!-- end payment section -->

            <!-- STATUS CHECKING SECTION -->
            <LinearLayout
                android:id="@+id/tez_checking_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="16dp"
                android:layout_marginBottom="6dp">

                <!-- Spinner wrap -->
                <FrameLayout
                    android:id="@+id/tez_spinner_wrap"
                    android:layout_width="88dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="14dp">

                    <ProgressBar
                        android:id="@+id/tez_status_spinner"
                        style="@android:style/Widget.ProgressBar.Large"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <ImageView
                        android:id="@+id/tez_spinner_logo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tez_status_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Checking status..."
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tez_status_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Checking... 0s"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="14dp" />

                <!-- Result Card -->
                <LinearLayout
                    android:id="@+id/tez_result_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tez_result_icon_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tez_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tez_result_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:textColor="#555555" />
                </LinearLayout>

                <!-- Check status button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_check_status"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Check Status Now"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
            <!-- end checking section -->

            <!-- CANCEL BUTTON (Neo brutalist flat red) -->
            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:text="Cancel Payment"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- NEWS TICKER -->
    <LinearLayout
        android:id="@+id/tez_news_ticker_container"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Left accent band -->
        <LinearLayout
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="#000000">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📢"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Ticker body border at top/bottom -->
        <TextView
            android:id="@+id/tez_news_ticker"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:background="#FFF8E1"
            android:textColor="#000000"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

</LinearLayout>
