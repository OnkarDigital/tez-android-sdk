<?xml version="1.0" encoding="utf-8"?>
<!--
    TezGateway SDK — Native Payment BottomSheet Layout  v1.0.10
    Header color: applied from CheckoutSettings.headerColor
    Branding badge: hidden when remove_branding = true
    QR "I've Paid" button: starts status polling for QR-scanned payments
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ── DRAG HANDLE ── -->
    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/tez_drag_handle_bg" />

    <!-- ══════════════════════════════════════
         HEADER BAR
    ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/tez_header_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="16dp"
        android:background="#c800b2">

        <!-- Lock badge -->
        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete Your Payment"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ "
                    android:textColor="#AAFFCC"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100% Secure  ·  Native UPI  ·  NPCI Certified"
                    android:textColor="#FFFFFF"
                    android:textSize="9.5sp"
                    android:alpha="0.75" />
            </LinearLayout>
        </LinearLayout>

        <!-- Powered by TezGateway — hidden when remove_branding = true -->
        <LinearLayout
            android:id="@+id/tez_branding_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:alpha="0.55"
                android:gravity="end" />

            <ImageView
                android:id="@+id/tez_branding_logo"
                android:layout_width="88dp"
                android:layout_height="22dp"
                android:scaleType="fitEnd"
                android:alpha="0.9"
                android:adjustViewBounds="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Header drop shadow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:background="@drawable/tez_header_shadow_bg" />

    <!-- ══════════════════════════════════════
         SCROLLABLE BODY
    ══════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="12dp">

            <!-- ══════════════════════════════════════
                 PAYMENT SELECTION SECTION
            ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/tez_payment_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── AMOUNT CARD ── -->
                <LinearLayout
                    android:id="@+id/tez_amount_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="20dp"
                    android:paddingBottom="18dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/tez_amount_card_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT TO PAY"
                        android:textSize="9.5sp"
                        android:textColor="#9E00A0"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tez_amount_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="38sp"
                        android:textStyle="bold"
                        android:textColor="#1a0030"
                        android:letterSpacing="-0.02"
                        tools:text="₹500.00" />

                    <!-- Thin accent line under amount -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="10dp"
                        android:background="#DDB8FF" />
                </LinearLayout>

                <!-- ── SECTION LABEL: UPI Apps ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tez_section_accent_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAY VIA UPI APP"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ── UPI APP BUTTONS GRID ── -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:useDefaultMargins="false"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_gpay"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Google Pay"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#1a73e8"
                        android:visibility="gone"
                        app:backgroundTint="#0A1a73e8"
                        app:strokeColor="#1a73e8"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_gpay"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_phonepe"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="PhonePe"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#5f259f"
                        android:visibility="gone"
                        app:backgroundTint="#0A5f259f"
                        app:strokeColor="#5f259f"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_phonepe"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paytm"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Paytm"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#0078AA"
                        android:visibility="gone"
                        app:backgroundTint="#0A00BAF2"
                        app:strokeColor="#00BAF2"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_paytm"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bhim"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="BHIM UPI"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#00529a"
                        android:visibility="gone"
                        app:backgroundTint="#0A00529a"
                        app:strokeColor="#00529a"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_bhim"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_amazonpay"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="Amazon Pay"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#C47600"
                        android:visibility="gone"
                        app:backgroundTint="#0AFF9900"
                        app:strokeColor="#FF9900"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_amazonpay"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cred"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:text="CRED"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="#1c1c1e"
                        android:visibility="gone"
                        app:backgroundTint="#061c1c1e"
                        app:strokeColor="#1c1c1e"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_cred"
                        app:iconGravity="top"
                        app:iconTint="@null"
                        app:iconSize="28dp"
                        app:iconPadding="4dp" />
                </GridLayout>

                <!-- ── TRUST ROW ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/tez_trust_row_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  Secure"
                        android:textSize="10sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#A5D6A7" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Fast"
                        android:textSize="10sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textSize="10sp"
                        android:textColor="#A5D6A7" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Native UPI"
                        android:textSize="10sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ── OR DIVIDER (shown only when QR is visible) ── -->
                <LinearLayout
                    android:id="@+id/tez_or_divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E8E8E8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR SCAN QR  "
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E8E8E8" />
                </LinearLayout>

                <!-- ── QR CARD ── -->
                <LinearLayout
                    android:id="@+id/tez_qr_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:background="@drawable/tez_qr_card_bg"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/tez_qr_image"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:scaleType="fitCenter"
                        android:background="#FFFFFF"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open any UPI app and scan this QR code"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:gravity="center"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_qr_paid"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="I've Paid — Check Status"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#c800b2"
                        app:cornerRadius="14dp"
                        app:elevation="0dp" />
                </LinearLayout>

            </LinearLayout>
            <!-- end tez_payment_section -->

            <!-- ══════════════════════════════════════
                 STATUS CHECKING SECTION
            ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/tez_checking_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="24dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/tez_status_card_bg">

                <!-- Spinner with logo centered inside -->
                <FrameLayout
                    android:id="@+id/tez_spinner_wrap"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginBottom="22dp">

                    <ProgressBar
                        android:id="@+id/tez_status_spinner"
                        style="@android:style/Widget.ProgressBar.Large"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminateTint="#c800b2" />

                    <ImageView
                        android:id="@+id/tez_spinner_logo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tez_status_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Verifying your payment..."
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1a0030"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tez_status_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Checking... 0s"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="24dp" />

                <!-- Result card -->
                <LinearLayout
                    android:id="@+id/tez_result_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/tez_result_card_bg"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tez_result_icon_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="52sp"
                        android:layout_marginBottom="10dp"
                        tools:text="✓" />

                    <TextView
                        android:id="@+id/tez_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp"
                        tools:text="Payment Successful!" />

                    <TextView
                        android:id="@+id/tez_result_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:textColor="#555555"
                        tools:text="UTR: 123456789012" />
                </LinearLayout>

                <!-- Check Status Now -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_check_status"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Check Status Now"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:textColor="#c800b2"
                    app:strokeColor="#c800b2"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@android:color/transparent"
                    android:layout_marginBottom="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
            <!-- end tez_checking_section -->

            <!-- ── CANCEL / DISMISS ── -->
            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="Cancel Payment"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:background="@drawable/tez_cancel_btn_bg"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── NEWS TICKER ── -->
    <LinearLayout
        android:id="@+id/tez_news_ticker_container"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Left accent band -->
        <LinearLayout
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="#FFB300">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📢"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tez_news_ticker"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:background="#FFF8E1"
            android:textColor="#6D4C00"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            tools:text="Important: Do not press back while payment is processing." />
    </LinearLayout>

</LinearLayout>
